  "usage_examples": {
    "python": [
      "import mlx.core as mx",
      "",
      "# Initialize distributed group",
      "group = mx.distributed.init(backend='ring')",
      "",
      "# Use optimized all_reduce with automatic algorithm selection",
      "x = mx.ones((1024, 1024))",
      "result = mx.distributed.all_reduce(x, op='sum')",
      "",
      "# Use optimized all_reduce with explicit algorithm (best for medium/large messages)",
      "result = mx.distributed.all_reduce_opt(x, op='sum', algo='tree')",
      "",
      "# All-gather with algorithm selection",
      "gathered = mx.distributed.all_gather_opt(x, algo='tree')",
      "",
      "# Reduce-scatter with algorithm selection",
      "scattered = mx.distributed.reduce_scatter_opt(x, op='sum', algo='tree')",
      "",
      "# Pipeline parallelism",
      "def forward_pass(x):",
      "    return mx.matmul(x, W1)",
      "",
      "stages = [",
      "    mx.distributed.PipelineStage(0, 4, forward_pass),",
      "]",
      "output = mx.distributed.execute_pipeline(stages, input_data)"
    ]
